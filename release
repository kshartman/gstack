#!/usr/bin/env bash
# gstack release — install/update gstack from git
set -e

REPO="git@github.com:kshartman/gstack.git"
DEST="$HOME/.claude/skills/gstack"
YES=0

# Parse options
while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) REPO="$2"; shift 2 ;;
    --path) DEST="$2"; shift 2 ;;
    -y) YES=1; shift ;;
    *) shift ;;
  esac
done

if ! command -v bun &>/dev/null; then
  echo "Error: bun is not installed."
  echo "Install it with:  curl -fsSL https://bun.sh/install | bash"
  echo "Then restart your shell and re-run this script."
  exit 1
fi

if [ ! -d "$DEST" ]; then
  if [ "$YES" -eq 0 ]; then
    read -rp "Clone gstack to $DEST? [y/N] " answer
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
  fi
  echo "Cloning $REPO to $DEST..."
  mkdir -p "$(dirname "$DEST")"
  git clone "$REPO" "$DEST"
fi

cd "$DEST"
git fetch origin
git reset --hard origin/main
bun install
bun run build

# Symlink skills into parent directory if needed
SKILLS_DIR="$(dirname "$DEST")"
linked=()
for skill_dir in "$DEST"/*/; do
  if [ -f "$skill_dir/SKILL.md" ]; then
    skill_name="$(basename "$skill_dir")"
    [ "$skill_name" = "node_modules" ] && continue
    target="$SKILLS_DIR/$skill_name"
    if [ ! -e "$target" ] && [ ! -L "$target" ]; then
      ln -snf "gstack/$skill_name" "$target"
      linked+=("$skill_name")
    fi
  fi
done

if [ ${#linked[@]} -gt 0 ]; then
  echo "  linked skills: ${linked[*]}"
fi

echo "gstack released to $DEST"
