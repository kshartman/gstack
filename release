#!/usr/bin/env bash
# gstack release — copy/update the active skill install
set -e

GSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
DEST="$HOME/.claude/skills/gstack"
YES=0

# Parse options
while [[ $# -gt 0 ]]; do
  case "$1" in
    --path) DEST="$2"; shift 2 ;;
    -y) YES=1; shift ;;
    *) shift ;;
  esac
done

if [ ! -d "$DEST" ]; then
  if [ "$YES" -eq 0 ]; then
    read -rp "Destination $DEST does not exist. Create it? [y/N] " answer
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
  fi
  echo "Copying fresh install to $DEST..."
  mkdir -p "$(dirname "$DEST")"
  cp -r "$GSTACK_DIR" "$DEST"
fi

cd "$DEST"
git reset --hard origin/main
bun install
bun run build

echo "gstack released to $DEST"
