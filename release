#!/usr/bin/env bash
# gstack release — copy/update the active skill install
set -e

GSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
DEST="$HOME/.claude/skills/gstack"

# Parse --path option
while [[ $# -gt 0 ]]; do
  case "$1" in
    --path) DEST="$2"; shift 2 ;;
    *) shift ;;
  esac
done

if [ ! -d "$DEST" ]; then
  echo "Destination not found — copying fresh install..."
  mkdir -p "$(dirname "$DEST")"
  cp -r "$GSTACK_DIR" "$DEST"
fi

cd "$DEST"
git reset --hard origin/main
bun install
bun run build

echo "gstack released to $DEST"
