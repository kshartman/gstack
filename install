#!/usr/bin/env bash
# gstack install — install or update gstack locally or on a remote host
#
# Usage:
#   ./install                        # install/update locally
#   ./install -y                     # skip prompts
#   ./install --host user@machine    # install/update on remote host via ssh
#   ./install --repo git@...         # use a different repo
#   ./install --path /custom/path    # custom install path
set -e

REPO="git@github.com:kshartman/gstack.git"
DEST="\$HOME/.claude/skills/gstack"
HOST=""
YES=0

# Parse options
while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) REPO="$2"; shift 2 ;;
    --path) DEST="$2"; shift 2 ;;
    --host) HOST="$2"; shift 2 ;;
    -y) YES=1; shift ;;
    *) shift ;;
  esac
done

# ─── Prereq check (local) ────────────────────────────────────
check_prereqs() {
  local missing=()
  command -v git &>/dev/null || missing+=(git)
  command -v curl &>/dev/null || missing+=(curl)
  if [ ${#missing[@]} -gt 0 ]; then
    echo "Error: missing required tools: ${missing[*]}"
    exit 1
  fi
}

# ─── Remote install via SSH ──────────────────────────────────
if [ -n "$HOST" ]; then
  echo "Installing gstack on $HOST..."
  # shellcheck disable=SC2087
  ssh "$HOST" bash -s -- "$REPO" "$DEST" "$YES" <<'REMOTE_SCRIPT'
set -e
REPO="$1"
DEST="$2"
YES="$3"
# Expand $HOME in DEST
DEST=$(eval echo "$DEST")

# Check prereqs
for cmd in git curl; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd is not installed on $(hostname)."
    exit 1
  fi
done

if ! command -v bun &>/dev/null; then
  if [ "$YES" -eq 1 ]; then
    echo "Installing bun..."
    curl -fsSL https://bun.sh/install | bash
    export BUN_INSTALL="$HOME/.bun"
    export PATH="$BUN_INSTALL/bin:$PATH"
  else
    echo "Error: bun is not installed on $(hostname)."
    echo "Run with -y to auto-install, or install manually:"
    echo "  curl -fsSL https://bun.sh/install | bash"
    exit 1
  fi
fi

if [ ! -d "$DEST" ]; then
  echo "Cloning $REPO to $DEST..."
  mkdir -p "$(dirname "$DEST")"
  git clone "$REPO" "$DEST"
fi

cd "$DEST"
git fetch origin
git reset --hard origin/main
bun install
bun run build

# Symlink skills
SKILLS_DIR="$(dirname "$DEST")"
for skill_dir in "$DEST"/*/; do
  if [ -f "$skill_dir/SKILL.md" ]; then
    skill_name="$(basename "$skill_dir")"
    [ "$skill_name" = "node_modules" ] && continue
    target="$SKILLS_DIR/$skill_name"
    if [ ! -e "$target" ] && [ ! -L "$target" ]; then
      ln -snf "gstack/$skill_name" "$target"
    fi
  fi
done

# Set default config
mkdir -p "$HOME/.gstack"
CFG="$HOME/.gstack/config.yaml"
for key_val in "upgrade_mode: manual" "telemetry: off"; do
  key="${key_val%%:*}"
  grep -q "^${key}:" "$CFG" 2>/dev/null || echo "$key_val" >> "$CFG"
done

echo "gstack installed on $(hostname) at $DEST"
REMOTE_SCRIPT
  exit $?
fi

# ─── Local install ───────────────────────────────────────────
DEST=$(eval echo "$DEST")
check_prereqs

if ! command -v bun &>/dev/null; then
  echo "Error: bun is not installed."
  echo "Install it with:  curl -fsSL https://bun.sh/install | bash"
  echo "Then restart your shell and re-run this script."
  exit 1
fi

if [ ! -d "$DEST" ]; then
  if [ "$YES" -eq 0 ]; then
    read -rp "Clone gstack to $DEST? [y/N] " answer
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
  fi
  echo "Cloning $REPO to $DEST..."
  mkdir -p "$(dirname "$DEST")"
  git clone "$REPO" "$DEST"
fi

cd "$DEST"
git fetch origin
git reset --hard origin/main
bun install
bun run build

# Symlink skills
SKILLS_DIR="$(dirname "$DEST")"
linked=()
for skill_dir in "$DEST"/*/; do
  if [ -f "$skill_dir/SKILL.md" ]; then
    skill_name="$(basename "$skill_dir")"
    [ "$skill_name" = "node_modules" ] && continue
    target="$SKILLS_DIR/$skill_name"
    if [ ! -e "$target" ] && [ ! -L "$target" ]; then
      ln -snf "gstack/$skill_name" "$target"
      linked+=("$skill_name")
    fi
  fi
done

if [ ${#linked[@]} -gt 0 ]; then
  echo "  linked skills: ${linked[*]}"
fi

# Set default config
mkdir -p "$HOME/.gstack"
CFG="$HOME/.gstack/config.yaml"
for key_val in "upgrade_mode: manual" "telemetry: off"; do
  key="${key_val%%:*}"
  grep -q "^${key}:" "$CFG" 2>/dev/null || echo "$key_val" >> "$CFG"
done

echo "gstack installed at $DEST"
