#!/usr/bin/env bash
# gstack install — install or update gstack locally or on a remote host
#
# Usage:
#   ./install                        # install/update locally
#   ./install -y                     # skip prompts
#   ./install --host user@machine    # install/update on remote host via ssh
#   ./install --repo git@...         # use a different repo
#   ./install --path /custom/path    # custom install path
set -e

REPO="git@github.com:kshartman/gstack.git"
DEST="\$HOME/.claude/skills/gstack"
HOST=""
YES=0
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ─── Install log ────────────────────────────────────────────
log_install() {
  local host="$1" version="$2"
  local logfile="$SCRIPT_DIR/install.log"
  local ts="$(date +%Y-%m-%d\ %H:%M:%S)"
  echo "$ts  $host  v$version" >> "$logfile"
}

# Parse options
while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo) REPO="$2"; shift 2 ;;
    --path) DEST="$2"; shift 2 ;;
    --host) HOST="$2"; shift 2 ;;
    -y) YES=1; shift ;;
    *) shift ;;
  esac
done

# ─── Prereq check (local) ────────────────────────────────────
check_prereqs() {
  local missing=()
  command -v git &>/dev/null || missing+=(git)
  command -v curl &>/dev/null || missing+=(curl)
  if [ ${#missing[@]} -gt 0 ]; then
    echo "Error: missing required tools: ${missing[*]}"
    exit 1
  fi
}

# ─── Ensure bun is in PATH ──────────────────────────────────
ensure_bun_path() {
  if ! command -v bun &>/dev/null; then
    if [ -x "$HOME/.bun/bin/bun" ]; then
      export BUN_INSTALL="$HOME/.bun"
      export PATH="$BUN_INSTALL/bin:$PATH"
    fi
  fi
}

# ─── Chromium deps check ────────────────────────────────────
check_browser_deps() {
  local dest="$1"
  local yes="$2"

  # Only relevant on Linux
  [ "$(uname -s)" = "Linux" ] || return 0

  # Try launching Chromium headless — if it works, nothing to do
  local browse_bin="$dest/browse/dist/browse"
  if [ -x "$browse_bin" ]; then
    if "$browse_bin" goto about:blank --snapshot text &>/dev/null; then
      return 0
    fi
  fi

  # Detect OS and required packages
  local os_id=""
  [ -f /etc/os-release ] && os_id="$(. /etc/os-release && echo "$ID")"

  local apt_pkgs="libnss3 libatk-bridge2.0-0t64 libdrm2 libxcomposite1 libxdamage1 libxrandr2 libgbm1 libasound2t64 libpango-1.0-0 libcairo2 libcups2t64 libxkbcommon0 libatspi2.0-0t64"
  local dnf_pkgs="nss atk at-spi2-atk libdrm libXcomposite libXdamage libXrandr mesa-libgbm alsa-lib pango cairo cups-libs libxkbcommon at-spi2-core"

  echo ""
  echo "  Browser skills (/browse, /qa, /design-review) need Chromium dependencies."
  case "$os_id" in
    ubuntu|debian|pop|linuxmint)
      if [ "$yes" -eq 1 ]; then
        echo "  Installing Chromium deps..."
        sudo apt-get install -y $apt_pkgs 2>&1 | tail -3
      else
        read -rp "  Install Chromium deps via sudo? [y/N] " answer
        if [[ "$answer" =~ ^[Yy]$ ]]; then
          sudo apt-get install -y $apt_pkgs 2>&1 | tail -3
        else
          echo "  Run manually when ready:"
          echo "    sudo apt install -y $apt_pkgs"
        fi
      fi
      ;;
    fedora|rhel|centos|rocky|alma)
      if [ "$yes" -eq 1 ]; then
        echo "  Installing Chromium deps..."
        sudo dnf install -y $dnf_pkgs 2>&1 | tail -3
      else
        read -rp "  Install Chromium deps via sudo? [y/N] " answer
        if [[ "$answer" =~ ^[Yy]$ ]]; then
          sudo dnf install -y $dnf_pkgs 2>&1 | tail -3
        else
          echo "  Run manually when ready:"
          echo "    sudo dnf install -y $dnf_pkgs"
        fi
      fi
      ;;
    *)
      echo "  Install Playwright Chromium deps for your OS:"
      echo "    npx playwright install-deps chromium"
      ;;
  esac
  echo "  Note: text-based skills work fine without this."
}

# ─── Remote install via SSH ──────────────────────────────────
if [ -n "$HOST" ]; then
  echo "Installing gstack on $HOST..."
  # shellcheck disable=SC2087
  ssh "$HOST" bash -s -- "$REPO" "$DEST" "$YES" <<'REMOTE_SCRIPT'
set -e
REPO="$1"
DEST="$2"
YES="$3"
# Expand $HOME in DEST
DEST=$(eval echo "$DEST")

# Check prereqs
for cmd in git curl; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd is not installed on $(hostname)."
    exit 1
  fi
done

# Ensure bun is in PATH (e.g. ~/.bun/bin)
if ! command -v bun &>/dev/null && [ -x "$HOME/.bun/bin/bun" ]; then
  export BUN_INSTALL="$HOME/.bun"
  export PATH="$BUN_INSTALL/bin:$PATH"
fi

if ! command -v bun &>/dev/null; then
  if [ "$YES" -eq 1 ]; then
    echo "Installing bun..."
    curl -fsSL https://bun.sh/install | bash
    export BUN_INSTALL="$HOME/.bun"
    export PATH="$BUN_INSTALL/bin:$PATH"
  else
    echo "Error: bun is not installed on $(hostname)."
    echo "Run with -y to auto-install, or install manually:"
    echo "  curl -fsSL https://bun.sh/install | bash"
    exit 1
  fi
fi

if [ ! -d "$DEST" ]; then
  echo "Cloning $REPO to $DEST..."
  mkdir -p "$(dirname "$DEST")"
  git clone "$REPO" "$DEST"
fi

cd "$DEST"
git fetch origin
git reset --hard origin/main
bun install
bun run build

# Symlink skills
SKILLS_DIR="$(dirname "$DEST")"
for skill_dir in "$DEST"/*/; do
  if [ -f "$skill_dir/SKILL.md" ]; then
    skill_name="$(basename "$skill_dir")"
    [ "$skill_name" = "node_modules" ] && continue
    target="$SKILLS_DIR/$skill_name"
    if [ ! -e "$target" ] && [ ! -L "$target" ]; then
      ln -snf "gstack/$skill_name" "$target"
    fi
  fi
done

# Set default config
mkdir -p "$HOME/.gstack"
CFG="$HOME/.gstack/config.yaml"
for key_val in "upgrade_mode: manual" "telemetry: off"; do
  key="${key_val%%:*}"
  grep -q "^${key}:" "$CFG" 2>/dev/null || echo "$key_val" >> "$CFG"
done

# Check Chromium deps for browser skills
if [ "$(uname -s)" = "Linux" ]; then
  BROWSE_OK=0
  BROWSE_BIN="$DEST/browse/dist/browse"
  if [ -x "$BROWSE_BIN" ] && "$BROWSE_BIN" goto about:blank --snapshot text &>/dev/null; then
    BROWSE_OK=1
  fi
  if [ "$BROWSE_OK" -eq 0 ]; then
    OS_ID=""
    [ -f /etc/os-release ] && OS_ID="$(. /etc/os-release && echo "$ID")"
    APT_PKGS="libnss3 libatk-bridge2.0-0t64 libdrm2 libxcomposite1 libxdamage1 libxrandr2 libgbm1 libasound2t64 libpango-1.0-0 libcairo2 libcups2t64 libxkbcommon0 libatspi2.0-0t64"
    DNF_PKGS="nss atk at-spi2-atk libdrm libXcomposite libXdamage libXrandr mesa-libgbm alsa-lib pango cairo cups-libs libxkbcommon at-spi2-core"
    echo ""
    echo "  Browser skills (/browse, /qa, /design-review) need Chromium dependencies."
    case "$OS_ID" in
      ubuntu|debian|pop|linuxmint)
        if [ "$YES" -eq 1 ]; then
          echo "  Installing Chromium deps..."
          sudo apt-get install -y $APT_PKGS 2>&1 | tail -3
        else
          echo "  Run manually:"
          echo "    sudo apt install -y $APT_PKGS"
        fi
        ;;
      fedora|rhel|centos|rocky|alma)
        if [ "$YES" -eq 1 ]; then
          echo "  Installing Chromium deps..."
          sudo dnf install -y $DNF_PKGS 2>&1 | tail -3
        else
          echo "  Run manually:"
          echo "    sudo dnf install -y $DNF_PKGS"
        fi
        ;;
      *)
        echo "  Install Playwright Chromium deps for your OS:"
        echo "    npx playwright install-deps chromium"
        ;;
    esac
    echo "  Note: text-based skills work fine without this."
  fi
fi

echo "gstack installed on $(hostname) at $DEST"
REMOTE_SCRIPT
  REMOTE_VER=$(ssh -o ConnectTimeout=5 "$HOST" "cat \$HOME/.claude/skills/gstack/VERSION 2>/dev/null" || echo "unknown")
  log_install "$HOST" "$REMOTE_VER"
  exit $?
fi

# ─── Local install ───────────────────────────────────────────
DEST=$(eval echo "$DEST")
check_prereqs
ensure_bun_path

if ! command -v bun &>/dev/null; then
  echo "Error: bun is not installed."
  echo "Install it with:  curl -fsSL https://bun.sh/install | bash"
  echo "Then restart your shell and re-run this script."
  exit 1
fi

if [ ! -d "$DEST" ]; then
  if [ "$YES" -eq 0 ]; then
    read -rp "Clone gstack to $DEST? [y/N] " answer
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
  fi
  echo "Cloning $REPO to $DEST..."
  mkdir -p "$(dirname "$DEST")"
  git clone "$REPO" "$DEST"
fi

cd "$DEST"
git fetch origin
git reset --hard origin/main
bun install
bun run build

# Symlink skills
SKILLS_DIR="$(dirname "$DEST")"
linked=()
for skill_dir in "$DEST"/*/; do
  if [ -f "$skill_dir/SKILL.md" ]; then
    skill_name="$(basename "$skill_dir")"
    [ "$skill_name" = "node_modules" ] && continue
    target="$SKILLS_DIR/$skill_name"
    if [ ! -e "$target" ] && [ ! -L "$target" ]; then
      ln -snf "gstack/$skill_name" "$target"
      linked+=("$skill_name")
    fi
  fi
done

if [ ${#linked[@]} -gt 0 ]; then
  echo "  linked skills: ${linked[*]}"
fi

# Set default config
mkdir -p "$HOME/.gstack"
CFG="$HOME/.gstack/config.yaml"
for key_val in "upgrade_mode: manual" "telemetry: off"; do
  key="${key_val%%:*}"
  grep -q "^${key}:" "$CFG" 2>/dev/null || echo "$key_val" >> "$CFG"
done

# Check Chromium deps for browser skills
check_browser_deps "$DEST" "$YES"

LOCAL_VER=$(cat "$DEST/VERSION" 2>/dev/null || echo "unknown")
log_install "$(hostname -s)" "$LOCAL_VER"
echo "gstack installed at $DEST"
